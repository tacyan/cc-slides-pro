.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ─── Dependencies ────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/install-state.gz

# ─── Build / generated output ────────────────────────────────
# 生成されたスライド画像。再現可能なのでコミット不要。
# 評価提出用などで残したい場合は examples/ 以下に手動でコピー。
output/
dist/
build/
.next/
.cache/
.parcel-cache/

